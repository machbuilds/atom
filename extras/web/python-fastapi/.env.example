# Python / FastAPI — environment contract.
#
# Copy this file to .env (gitignored) and fill in the values you need.
# Pydantic Settings reads .env at startup; missing values fall back to
# the defaults declared in app/main.py:Settings.

# Runtime mode: dev | staging | prod
APP_ENV=dev

# uvicorn log level: debug | info | warning | error | critical
LOG_LEVEL=info

# Worker count. Default in Dockerfile is 2; rule of thumb is 2*cpu+1
# for IO-bound workloads. Bump only if you have evidence you need it.
UVICORN_WORKERS=2

# Optional: external services (uncomment + set as you wire them up)
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/db
# REDIS_URL=redis://localhost:6379/0
