# Rust / Axum — environment contract.
#
# Copy this file to .env (gitignored) and fill in values you need.
# main.rs reads these via std::env::var; missing values fall back to
# the defaults declared in code.

# Listen port (default: 8080)
PORT=8080

# Tracing filter. Examples:
#   info                                 (everything at info)
#   info,app=debug                       (debug for our crate, info elsewhere)
#   warn,app=trace,tower_http=debug      (per-crate granularity)
RUST_LOG=info,app=debug
