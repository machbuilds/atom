.env
.env.*
!.env.example

# Editor / OS
.DS_Store
.vscode
.idea
*.swp
*.xcodeproj
*.xcworkspace

# Docker (avoid recursive context)
Dockerfile
Dockerfile.*
docker-compose*.yml
.dockerignore
.devcontainer

# atom planning artifacts
docs/planning
.atom-setup-state.json

# Misc
*.log
README.md
DEPLOY.md
