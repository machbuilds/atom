# Swift / Vapor — environment contract.
#
# Copy this file to .env (gitignored) and fill in values you need.
# Vapor reads PORT and the env-name passed via --env; everything else
# is read in configure.swift via Environment.get().

# Listen port (default: 8080)
PORT=8080

# Optional: log level. Vapor honors LOG_LEVEL when it's one of:
# trace, debug, info, notice, warning, error, critical
LOG_LEVEL=info
