# Dockerfile.example
#
# This is a generic multi-stage Node.js Dockerfile starting point. It is
# NOT a working example for any specific stack — adapt it to your project
# or replace it entirely.
#
# - For Next.js + Railway, use the preset in atom's
#   extras/web/nextjs-railway/ instead.
# - For Python services, replace the FROM with python:3.12-slim and
#   adjust accordingly.
# - For Go services, use a multi-stage with golang:1.22-alpine builder
#   and a minimal scratch/alpine final image.
#
# When you fill this in, rename to `Dockerfile` (no .example suffix).
# If your project doesn't ship as a container, delete this file.

# syntax=docker/dockerfile:1.6

FROM node:20-alpine AS deps
RUN apk add --no-cache libc6-compat
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci

FROM node:20-alpine AS builder
WORKDIR /app

# <TODO: declare ARG for any NEXT_PUBLIC_* / build-time env vars
# the project needs inlined into the client bundle. Otherwise they
# default to undefined during build and fall back at runtime.>
# Example:
#   ARG NEXT_PUBLIC_BASE_URL
#   ENV NEXT_PUBLIC_BASE_URL=$NEXT_PUBLIC_BASE_URL

COPY --from=deps /app/node_modules ./node_modules
COPY . .
RUN npm run build

FROM node:20-alpine AS runner
WORKDIR /app
ENV NODE_ENV=production

RUN addgroup --system --gid 1001 nodejs \
 && adduser --system --uid 1001 appuser

# <TODO: copy your build output. Adjust paths to match your framework:
#   Next.js standalone:  COPY --from=builder /app/.next/standalone ./
#                        COPY --from=builder /app/.next/static ./.next/static
#                        COPY --from=builder /app/public ./public
#   Vite SPA:            COPY --from=builder /app/dist ./dist
#                        # then serve with a static file server
#   Generic Node:        COPY --from=builder /app/dist ./dist
#                        COPY --from=builder /app/node_modules ./node_modules
#                        COPY package.json ./
# >

USER appuser
EXPOSE 3000
ENV PORT=3000
ENV HOSTNAME=0.0.0.0

# <TODO: replace with your start command>
CMD ["node", "server.js"]
